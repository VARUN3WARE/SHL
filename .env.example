# --- Security ---
# Never commit real keys. If a key was exposed in chat/logs, rotate it in Google AI Studio.
# GEMINI_API_KEY=

# Optional: disable model calls while keeping embeddings
# USE_GEMINI=false

# Fast models: gemini-2.0-flash, gemini-1.5-flash, etc.
# GEMINI_MODEL=gemini-2.0-flash

# Seconds (keep low vs CHAT timeout ~29s)
# GEMINI_TIMEOUT_S=8

# --- Catalog ---
# SHL_CATALOG_PATH=/absolute/path/to/shl_product_catalog.json

# --- Local embeddings (sentence-transformers) ---
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_INDEX_PATH=/absolute/path/to/catalog_embeddings.npz

# Hybrid retrieval weights (semantic vs lexical overlap)
# HYBRID_W_SEM=0.55
# HYBRID_W_LEX=0.45
